# Caddy 反向代理配置 - jiezispace.com
# 更简单，自动 HTTPS

jiezispace.com, www.jiezispace.com {
    # 代理到 Docker 应用
    reverse_proxy localhost:8080

    # 日志
    log {
        output file /var/log/caddy/access.log
    }

    # 可选：设置静态文件缓存
    header {
        # 缓存 CSS/JS/图片 1 年
        Cache-Control "public, max-age=31536000" {
            match {
                header User-Agent ".*"
                path "*.css" "*.js" "*.png" "*.jpg" "*.jpeg" "*.gif" "*.ico" "*.svg"
            }
        }
        # API 响应不缓存
        Cache-Control "no-cache, no-store, must-revalidate"
    }
}

# 本地开发配置（可选）
localhost:8081 {
    # 如果需要本地测试反向代理
    reverse_proxy localhost:8080
}
