# PostgreSQL 配置
POSTGRES_USER=codecopy
POSTGRES_PASSWORD=codecopy123
POSTGRES_DB=codecopybook
POSTGRES_PORT=5432

# 应用程序配置
PORT=8080
AUTH_SECRET=your-secret-key-change-in-production
DATA_DIR=/data

# 数据库连接URL
DATABASE_URL=postgres://codecopy:codecopy123@postgres:5432/codecopybook?sslmode=disable

# ==================== 文件存储配置 ====================
# 存储类型：local（本地文件系统） 或 s3（对象存储）
STORAGE_TYPE=local

# ==================== 缤纷云 S3 配置 ====================
# 注意：使用 S3 存储时，请填写以下配置
# 从缤纷云控制台获取：https://console.bitiful.com/

# S3 服务端点（请根据实际情况填写）
S3_ENDPOINT=https://s3.bitiful.net

# S3 区域（请根据实际情况填写）
S3_REGION=cn-east-1

# S3 访问凭证（从缤纷云控制台创建）
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here

# 用户文件存储 Bucket
S3_BUCKET=codejym-uploads

# 数据库备份 Bucket（可选，不配置则使用 S3_BUCKET）
S3_BACKUP_BUCKET=codejym-backups

# CDN URL 前缀（可选，配置后可加速文件访问）
# 示例：https://cdn.yourdomain.com
S3_URL_PREFIX=
